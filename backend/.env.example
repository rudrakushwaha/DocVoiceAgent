# DocAI Backend Environment Variables

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Python RAG Service URL
PYTHON_RAG_URL=http://localhost:8000/query-rag

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/docvoice

# Firebase Service Account (if using Firebase auth)
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./firebase-service-account.json

# Port
PORT=4000

# Agent Layer - n8n Webhook URLs (optional - will simulate if not set)
N8N_EMAIL_WEBHOOK_URL=https://your-n8n-instance.com/webhook/email
N8N_SCHEDULER_WEBHOOK_URL=https://your-n8n-instance.com/webhook/scheduler

# Other existing environment variables...
# Add any additional variables your system needs
